---
title: "Excalivault Docs"
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <nav class="fixed left-0 top-0 h-full w-64 bg-sidebar border-r border-sidebar-border p-4">
    <div class="mb-8">
      <h2 class="text-xl font-bold text-sidebar-foreground">Excalivault</h2>
      <p class="text-sm text-muted-foreground">Documentation</p>
    </div>
    <ul class="space-y-2">
      <li>
        <a href="/" class="block px-3 py-2 rounded-md text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">
          Home
        </a>
      </li>
      <li>
        <a href="/installation" class="block px-3 py-2 rounded-md text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">
          Installation
        </a>
      </li>
      <li>
        <a href="/how-it-works" class="block px-3 py-2 rounded-md text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">
          How It Works
        </a>
      </li>
      <li>
        <a href="/privacy" class="block px-3 py-2 rounded-md text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">
          Privacy
        </a>
      </li>
    </ul>
  </nav>
  <main class="ml-64 p-8">
    <h1 class="text-4xl font-bold mb-4">Welcome to Excalivault</h1>
    <p class="text-muted-foreground mb-8">
      Personal vault for storing Excalidraws
    </p>
    <div class="grid gap-6">
      <section class="bg-card border border-border rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-2">Quick Start</h2>
        <ul class="list-disc pl-5 space-y-1">
          <li>Install from the Chrome Web Store</li>
          <li>Open the side panel</li>
          <li>Start saving your Excalidraws!</li>
        </ul>
      </section>
      <section class="bg-card border border-border rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-2">Features</h2>
        <ul class="list-disc pl-5 space-y-1">
          <li>Folder Organization</li>
          <li>Local Storage</li>
          <li>Privacy First</li>
          <li>Thumbnails</li>
          <li>Fast & Lightweight</li>
        </ul>
      </section>
    </div>
  </main>
</Layout>
