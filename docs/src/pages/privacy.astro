---
title: "Privacy"
import Layout from '../layouts/Layout.astro';
import { Home, Download, Cpu, ShieldCheck } from '@lucide/astro';
---

<Layout>
  <nav class="fixed left-0 top-0 h-full w-64 bg-sidebar border-r border-sidebar-border p-4">
    <div class="mb-8">
      <div class="flex items-center gap-2 mb-1">
        <img src="/icon.png" alt="Excalivault" class="w-8 h-8" />
        <h2 class="text-xl font-bold text-sidebar-foreground">Excalivault</h2>
      </div>
      <p class="text-sm text-muted-foreground">Documentation</p>
    </div>
    <ul class="space-y-2">
      <li>
        <a href="/" class="flex items-center gap-3 px-3 py-2 rounded-md text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">
          <Home class="w-4 h-4" />
          Home
        </a>
      </li>
      <li>
        <a href="/installation" class="flex items-center gap-3 px-3 py-2 rounded-md text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">
          <Download class="w-4 h-4" />
          Installation
        </a>
      </li>
      <li>
        <a href="/how-it-works" class="flex items-center gap-3 px-3 py-2 rounded-md text-sidebar-foreground hover:bg-sidebar-accent hover:text-sidebar-accent-foreground">
          <Cpu class="w-4 h-4" />
          How It Works
        </a>
      </li>
      <li>
        <a href="/privacy" class="flex items-center gap-3 px-3 py-2 rounded-md bg-primary text-primary-foreground font-medium">
          <ShieldCheck class="w-4 h-4" />
          Privacy
        </a>
      </li>
    </ul>
  </nav>
  <main class="ml-64 p-8">
    <div class="max-w-4xl">
    <h1 class="text-4xl font-bold mb-4">Privacy Policy</h1>
    <p class="text-muted-foreground mb-8">
      Last Updated: March 8, 2026
    </p>
    <div class="grid gap-6">
      <section class="bg-card border border-border rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-4">Data Collection</h2>
        <p class="text-muted-foreground mb-4">
          Excalivault is a privacy-focused extension. We believe in local-first data storage.
        </p>
        <h3 class="text-xl font-semibold mb-2">What We Collect</h3>
        <p class="text-muted-foreground mb-4">
          <strong>We do NOT collect any data.</strong> Period.
        </p>
        <p class="text-muted-foreground mb-4">
          Your drawings and folders are stored <strong>only</strong> in your browser's local storage (chrome.storage.local). Your data stays on your device:
        </p>
        <ul class="list-none space-y-1 mb-4">
          <li>✅ No servers - your data never leaves your device</li>
          <li>✅ No tracking - we don't track usage or analytics</li>
          <li>✅ No personal data - we don't collect personal information</li>
          <li>✅ No cookies - we don't use cookies or third-party tracking</li>
        </ul>
        <h3 class="text-xl font-semibold mb-2">What Data Is Stored Locally</h3>
        <p class="text-muted-foreground">
          All data stays on your device:
        </p>
        <ul class="list-disc pl-5 space-y-1">
          <li><strong>Drawings</strong> - Elements, app state, and thumbnails</li>
          <li><strong>Folders</strong> - Organization structure</li>
          <li><strong>Settings</strong> - Your preferences</li>
        </ul>
        <p class="text-muted-foreground mt-4">
          This data is never transmitted outside your browser.
        </p>
      </section>
      <section class="bg-card border border-border rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-4">Permissions Required</h2>
        <p class="text-muted-foreground mb-4">
          Excalivault requests minimal permissions to function:
        </p>
        <div class="space-y-4">
          <div class="bg-muted p-4 rounded">
            <h3 class="text-lg font-semibold mb-2">storage</h3>
            <p class="text-muted-foreground text-sm mb-2"><strong>Purpose:</strong> Save drawings and folders locally</p>
            <p class="text-muted-foreground text-sm mb-2"><strong>Data Access:</strong> Only your own Excalidraw data</p>
            <p class="text-muted-foreground text-sm"><strong>Network Access:</strong> None (data never leaves your device)</p>
          </div>
          <div class="bg-muted p-4 rounded">
            <h3 class="text-lg font-semibold mb-2">sidePanel</h3>
            <p class="text-muted-foreground text-sm mb-2"><strong>Purpose:</strong> Display the vault interface</p>
            <p class="text-muted-foreground text-sm mb-2"><strong>Data Access:</strong> UI rendering only</p>
            <p class="text-muted-foreground text-sm"><strong>Network Access:</strong> None</p>
          </div>
          <div class="bg-muted p-4 rounded">
            <h3 class="text-lg font-semibold mb-2">activeTab</h3>
            <p class="text-muted-foreground text-sm mb-2"><strong>Purpose:</strong> Access Excalidraw.com to save/load drawings</p>
            <p class="text-muted-foreground text-sm mb-2"><strong>Data Access:</strong> Only reads Excalidraw's localStorage</p>
            <p class="text-muted-foreground text-sm"><strong>Network Access:</strong> None</p>
          </div>
        </div>
      </section>
      <section class="bg-card border border-border rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-4">Data Deletion</h2>
        <p class="text-muted-foreground mb-4">
          To delete all Excalivault data:
        </p>
        <ol class="list-decimal pl-5 space-y-2">
          <li>Open Chrome Settings → Extensions → Excalivault</li>
          <li>Click "Remove"</li>
          <li>All local data is automatically deleted</li>
        </ol>
        <p class="text-muted-foreground mt-4">
          Alternatively, you can clear individual drawings or folders from the vault UI.
        </p>
      </section>
      <section class="bg-card border border-border rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-4">Third-Party Services</h2>
        <p class="text-muted-foreground">
          Excalivault does not use any third-party services, APIs, or analytics.
        </p>
      </section>
      <section class="bg-card border border-border rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-4">Excalidraw Integration</h2>
        <p class="text-muted-foreground mb-4">
          Excalivault integrates with <a href="https://excalidraw.com" class="text-primary hover:underline">excalidraw.com</a>:
        </p>
        <ul class="list-disc pl-5 space-y-1">
          <li>We only read/write to Excalidraw's localStorage</li>
          <li>No data is sent to Excalidraw's servers</li>
          <li>Excalidraw's own privacy policy applies when you use their platform</li>
        </ul>
      </section>
      <section class="bg-card border border-border rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-4">Open Source</h2>
        <p class="text-muted-foreground mb-4">
          Excalivault is open source. You can review our code at:
        </p>
        <a href="#" class="text-primary hover:underline">GitHub Repository</a>
      </section>
      <section class="bg-card border border-border rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-4">Contact</h2>
        <p class="text-muted-foreground mb-4">
          If you have questions about privacy or find a security issue, please:
        </p>
        <ul class="list-disc pl-5 space-y-1">
          <li>Open an issue on GitHub</li>
          <li>Email: privacy@excalivault.com</li>
        </ul>
      </section>
      <section class="bg-card border border-border rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-4">Changes to This Policy</h2>
        <p class="text-muted-foreground">
          We will update this page if our data handling practices change. Changes will be posted with the date of revision.
        </p>
      </section>
      <section class="bg-card border border-border rounded-lg p-6">
        <h2 class="text-2xl font-bold mb-4">Summary</h2>
        <table class="w-full text-left">
          <thead>
            <tr class="border-b border-border">
              <th class="py-2">Aspect</th>
              <th class="py-2">Status</th>
            </tr>
          </thead>
          <tbody>
            <tr class="border-b border-border">
              <td class="py-2">Cloud storage</td>
              <td class="py-2">❌ None</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-2">Analytics</td>
              <td class="py-2">❌ None</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-2">Tracking</td>
              <td class="py-2">❌ None</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-2">Data sharing</td>
              <td class="py-2">❌ None</td>
            </tr>
            <tr class="border-b border-border">
              <td class="py-2">Local storage</td>
              <td class="py-2">✅ All data</td>
            </tr>
            <tr>
              <td class="py-2">Open source</td>
              <td class="py-2">✅ Reviewable code</td>
            </tr>
          </tbody>
        </table>
        <p class="text-muted-foreground mt-6 font-semibold">
          Your privacy is not for sale. It's never been, and it never will be.
        </p>
      </section>
    </div>
    </div>
  </main>
</Layout>
